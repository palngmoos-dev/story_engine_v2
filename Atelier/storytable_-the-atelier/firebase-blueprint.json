{
  "entities": {
    "Story": {
      "title": "Generated Story",
      "description": "A story generated by the AI Atelier",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Title of the story" },
        "logline": { "type": "string", "description": "One sentence summary" },
        "synopsis": { "type": "string", "description": "Long form description" },
        "scenes": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "title": { "type": "string" },
              "description": { "type": "string" }
            }
          }
        },
        "nextSteps": { "type": "string" },
        "userId": { "type": "string" },
        "mode": { "type": "string", "enum": ["beginner", "expert"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "logline", "synopsis", "userId", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}/stories/{storyId}": {
      "schema": "Story",
      "description": "Collection of stories saved by a user"
    }
  }
}
