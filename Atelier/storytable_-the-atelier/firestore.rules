rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidStory(data) {
      return data.size() >= 5 &&
             data.title is string && data.title.size() <= 200 &&
             data.logline is string && data.logline.size() <= 500 &&
             data.synopsis is string && data.synopsis.size() <= 5000 &&
             data.userId == request.auth.uid &&
             data.createdAt == request.time;
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      
      match /stories/{storyId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidStory(request.resource.data);
        allow delete: if isOwner(userId);
      }
    }
  }
}
